DirectoryIndex index.html

# ── HTTPS redirect ────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Gzip compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

# ── Cache headers ─────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML — pas de cache (contenu modifié fréquemment)
  ExpiresByType text/html                  "access plus 0 seconds"
  # CSS / JS — 1 an (cache-busting via ?v=N dans les URLs)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType text/javascript            "access plus 1 year"
  # Fonts — 1 an
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType application/font-woff2     "access plus 1 year"
  # Images — 1 an
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
</IfModule>

# ── Cache-Control immutable pour assets versionnés ────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|woff|webp|png|jpg|jpeg|gif|svg)$">
    Header append Cache-Control "immutable"
  </FilesMatch>
</IfModule>

# ── Security headers ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS — force HTTPS pour 1 an (activer seulement quand HTTPS stable sur paranoir.fr)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # CSP — sources autorisées (ajuster si GA4 ou autres tiers ajoutés)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-src https://buy.stripe.com https://meet.brevo.com; object-src 'none'; base-uri 'self'"
</IfModule>

# ── Erreurs custom ────────────────────────────────────────────────
ErrorDocument 404 /index.html
